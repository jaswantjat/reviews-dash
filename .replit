modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=8080 pnpm run start"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/dashboard && PORT=3000 BASE_PATH=/ pnpm run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
PLACE_ID_ELTEX = "ChIJhTCaeeajpBIR4O9YniCqiJ0"
SCRAPING_DOG_API_KEY = "69c93a0dc12e078c544a57d8"
HASDATA_API_KEY = "c7d8134a-3e82-45db-b8d4-ed252eec9261"
SEARCHAPI_KEY = "2BcSHdpwMRps8xR611yFUaPW"
DATA_ID_ELTEX = "0x12a4a3e6799a3085:0x9d88aa209e58efe0"
SUPABASE_PAT = "sbp_cb056a032c429b68f5659d80bc731e0bb7ce4c10"
SEARCHAPI_KEY_BACKUP = "MCi58AMSXWC593ykzikBAaZC"
APIFY_API_KEY = "apify_api_ijQwHpf6EaJleup32PTcgnZCzghs5F2wjHI7"
APIFY_API_KEY_BACKUP = "apify_api_oRnOWsTuQg0caGqt4VRpBB2U8pEcjq0m1Quk"
POLL_HOUR_UTC = "6"

[nix]
channel = "stable-25_05"
